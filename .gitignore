# Ignore downloaded source trees, dependencies, build outputs, caches, and logs.
*

# Keep repository metadata and documentation.
!/.gitignore
!/README.md
!/docs/
!/docs/**

# Keep empty directory skeleton markers.
!/**/
!**/.gitkeep

# Always ignore generated runtime/build areas.
/build_logs/**
/test_logs/**
/tmp/**
/ddc/**
/venvs/**
/carla/**
/ue/**
/scenario_runner/**
